# LLM Configuration Example
# Copy this file to .env and fill in your actual credentials.
# DO NOT commit the .env file to version control.

# --- OpenAI Example ---
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="https://api.openai.com/v1" # Optional: if using a proxy or alternative endpoint

# --- Other LLM Provider Example ---
# OTHER_LLM_API_KEY="your-other-key"
# OTHER_LLM_ENDPOINT="https://api.example-llm.com"

# --- News Analyzer Specific (if any) ---
# e.g., SOME_SERVICE_API_KEY="..."